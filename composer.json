{
    "name": "ucr/bovweight-patrones-lab",
    "description": "Laboratorio de Catálogo de Patrones (Factory, Repository, Observer, Strategy) - BovWeight CR - IF7100",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Estudiante IF7100",
            "email": "estudiante@ucr.ac.cr"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "BovWeight\\Lab\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BovWeight\\Lab\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "demo": [
            "php examples/demo_factory.php",
            "php examples/demo_repository.php",
            "php examples/demo_observer.php",
            "php examples/demo_strategy.php"
        ]
    }
}
